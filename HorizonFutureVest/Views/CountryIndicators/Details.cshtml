@model Application.ViewModels.CountryIndicatorViewModel

@{
    ViewData["Title"] = "Detalles del Indicador de País";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-body">
            <h2 class="mb-4">Detalles del Indicador de País</h2>
            <dl class="row">
                <dt class="col-sm-4">País</dt>
                <dd class="col-sm-8">@Model.CountryId</dd>
                <dt class="col-sm-4">Indicador Macro</dt>
                <dd class="col-sm-8">@Model.MacroIndicatorId</dd>
                <dt class="col-sm-4">Valor</dt>
                <dd class="col-sm-8">@Model.Value</dd>
                <dt class="col-sm-4">Año</dt>
                <dd class="col-sm-8">@Model.Year</dd>
            </dl>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary bg-navy">Editar</a>
            <a asp-action="Index" class="btn btn-secondary ms-2">Volver</a>
        </div>
    </div>
</div>



