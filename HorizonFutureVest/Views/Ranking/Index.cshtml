@model IEnumerable<Application.ViewModels.CountryRankingViewModel>

@{
    ViewData["Title"] = "Ranking de Países";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Ranking de Países (@ViewBag.year)</h2>
        <form method="get" asp-action="Index" class="d-flex align-items-center">
            <label for="year" class="me-2 mb-0">Año:</label>
            <input type="number" name="year" id="year" value="@ViewBag.year" class="form-control me-2" style="width:120px;" />
            <button type="submit" class="btn btn-primary bg-navy">Cargar</button>
        </form>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Posición</th>
                        <th>País</th>
                        <th>Puntaje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Position</td>
                            <td>@item.CountryName</td>
                            <td>@item.Score.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


