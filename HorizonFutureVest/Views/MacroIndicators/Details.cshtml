@model Application.ViewModels.MacroIndicatorViewModel

@{
    ViewData["Title"] = "Detalles del Indicador Macro";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-body">
            <h2 class="mb-4">Detalles del Indicador Macro</h2>
            <dl class="row">
                <dt class="col-sm-4">Nombre</dt>
                <dd class="col-sm-8">@Model.Name</dd>
                <dt class="col-sm-4">Peso</dt>
                <dd class="col-sm-8">@Model.Weight</dd>
            </dl>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary bg-navy">Editar</a>
            <a asp-action="Index" class="btn btn-secondary ms-2">Volver</a>
        </div>
    </div>
</div>



